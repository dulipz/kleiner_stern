---
import Base from '../layouts/Base.astro';
// Hero variants - swap the import to change the look:
//   HeroV1.astro = night sky + golden circle emblem + ribbon
//   HeroV2.astro = full-bleed ribbon photo, black & white text
import Hero from '../components/HeroV2.astro';
import Quote from '../components/Quote.astro';
import EnilaFeature from '../components/EnilaFeature.astro';
import Release from '../components/Release.astro';
import SongPlayer from '../components/SongPlayer.astro';
import Pricing from '../components/Pricing.astro';
import Mission from '../components/Mission.astro';
import ShopTeaser from '../components/ShopTeaser.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Kleiner Stern ganz groß | Ein Song. Eine Mission. Ein Herz für Kinder.">
  <Hero />
  <Quote />
  <EnilaFeature />
  <Release />
  <SongPlayer />
  <Pricing />
  <Mission />
  <ShopTeaser />
  <FinalCta />
  <Footer />
</Base>
