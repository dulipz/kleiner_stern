---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Danke | Kleiner Stern ganz groß">
  <section class="thanks">
    <div class="container">
      <div class="star" aria-hidden="true">
        <svg viewBox="0 0 100 100" width="80" height="80">
          <defs>
            <linearGradient id="tg" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#f8e6c0"/>
              <stop offset="1" stop-color="#c9a876"/>
            </linearGradient>
          </defs>
          <path d="M50 6 L60.5 38.5 L94 39 L67 59.5 L77 92 L50 72.5 L23 92 L33 59.5 L6 39 L39.5 38.5 Z" fill="url(#tg)"/>
        </svg>
      </div>
      <h1 class="script">Danke.</h1>
      <p class="serif message" id="msg">
        Du hast gerade einem Kind einen kleinen Stern geschenkt.
      </p>
      <p class="sub">
        50 % der Einnahmen gehen direkt an die Kinder Krebs Aktion Deutschland e.V.
      </p>

      <div class="download-box" id="download-box" hidden>
        <a class="btn-gold" id="download-link" href="#" download>
          ⬇ &nbsp;Song herunterladen (MP3)
        </a>
        <p class="download-note">
          Tipp: Speichere dir diese Seite. Der Download-Link funktioniert auch später noch.
        </p>
      </div>

      <a href="/" class="btn-ghost">Zurück zur Startseite</a>
    </div>
  </section>
  <Footer />
</Base>

<script>
  const params = new URLSearchParams(location.search);
  const typ = params.get('typ');
  const sessionId = params.get('session_id');
  const msg = document.getElementById('msg');
  if (msg && typ === 'spende') {
    msg.textContent = 'Deine Spende schenkt Hoffnung, Mut und einen kleinen Stern.';
  }
  if (msg && typ === 'shop') {
    msg.textContent = 'Deine Bestellung ist eingegangen und schenkt einem Kind einen kleinen Stern.';
  }

  // Song purchase: show the verified download button
  if (typ === 'song' && sessionId) {
    const box = document.getElementById('download-box');
    const link = document.getElementById('download-link');
    if (box && link) {
      link.setAttribute('href', `/api/download?session_id=${encodeURIComponent(sessionId)}`);
      box.hidden = false;
    }
  }
</script>

<style>
  .thanks {
    min-height: 80svh;
    display: grid;
    place-items: center;
    text-align: center;
    background:
      radial-gradient(ellipse 60% 45% at 50% 30%, rgba(201, 168, 118, 0.14), transparent 70%),
      var(--bg-deep);
  }

  .container { display: flex; flex-direction: column; align-items: center; gap: 1.8rem; }

  .star { filter: drop-shadow(0 0 30px rgba(238, 208, 152, 0.6)); }

  h1 { font-size: clamp(4rem, 10vw, 6rem); }

  .message {
    font-style: italic;
    font-size: clamp(1.4rem, 3vw, 2rem);
    max-width: 24em;
  }

  .sub { color: var(--text-muted); }

  .download-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
    padding: 1.8rem 2.2rem;
    background: rgba(20, 25, 27, 0.55);
    border: 1px solid rgba(238, 208, 152, 0.2);
    border-radius: 10px;
  }

  .download-note {
    font-size: 0.8rem;
    color: var(--text-muted);
    max-width: 34ch;
    text-align: center;
  }
</style>
