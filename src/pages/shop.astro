---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import Footer from '../components/Footer.astro';

// Product catalog (display only - prices are enforced server-side
// in functions/api/shop.js; keep both in sync).
const products = [
  {
    id: 'salt',
    name: 'Himalaya Pink Salt · Charity Edition',
    price: '9,99 €',
    unit: '1000 g',
    image: '/images/shop-salt.jpg',
    text: '100 % naturbelassenes Steinsalz, reich an Mineralien. Mit jedem verkauften Beutel unterstützt du krebskranke Kinder, direkt und ohne Umwege.',
    badge: 'Charity-Produkt',
  },
];
---

<Base title="Shop | Kleiner Stern ganz groß">
  <PageIntro
    eyebrow="Charity-Shop"
    title="Kaufen. Helfen. Hoffnung schenken."
    subtitle="Jedes Produkt unterstützt das Projekt „Kleiner Stern ganz groß“ und damit die Kinder Krebs Aktion Deutschland e.V."
    image="/images/hero-4.jpg"
    imageAlt="Kinderhand legt eine goldene Schleife in eine geöffnete Erwachsenenhand"
  />

  <section class="shop">
    <div class="container">
      <div class="products">
        {products.map((p) => (
          <article class="product reveal" data-product={p.id}>
            <figure class="product-img">
              <img src={p.image} alt={p.name} loading="lazy" />
              <span class="badge eyebrow">{p.badge}</span>
            </figure>
            <div class="product-body">
              <h2 class="serif name">{p.name}</h2>
              <p class="unit eyebrow">{p.unit}</p>
              <p class="text">{p.text}</p>
              <div class="buy-row">
                <p class="serif price">{p.price}</p>
                <label class="qty">
                  Menge
                  <select class="js-qty">
                    {[1, 2, 3, 4, 5].map((n) => <option value={n}>{n}</option>)}
                  </select>
                </label>
                <button class="btn-gold js-buy-product" data-product={p.id}>
                  In den Warenkorb · direkt zur Kasse
                </button>
              </div>
              <p class="hint js-hint"></p>
            </div>
          </article>
        ))}
      </div>

      <!-- advert -->
      <aside class="advert reveal">
        <figure class="advert-img">
          <img
            src="/images/shop-advert.jpg"
            alt="Enilaangel in der Salzgrotte mit Himalaya Pink Salt"
            loading="lazy"
          />
        </figure>
        <div class="advert-copy">
          <h2 class="serif">Aus der Salzgrotte<br />direkt zu dir.</h2>
          <p>
            Weitere Charity-Produkte folgen in Kürze, schau bald wieder
            vorbei. Für den Topgear Ball geht es
            <a href="https://topgear-sport.de" target="_blank" rel="noopener">hier entlang</a>.
          </p>
        </div>
      </aside>

      <p class="legal-note">
        Versand innerhalb Deutschlands, Österreichs und der Schweiz.
        Die Zahlung wird sicher über Stripe abgewickelt.
      </p>
    </div>
  </section>

  <Footer />
</Base>

<script>
  document.querySelectorAll('.js-buy-product').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const card = btn.closest('.product') as HTMLElement;
      const qty = Number((card.querySelector('.js-qty') as HTMLSelectElement).value);
      const hint = card.querySelector('.js-hint') as HTMLElement;
      (btn as HTMLButtonElement).disabled = true;
      try {
        const res = await fetch('/api/shop', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ product: card.dataset.product, quantity: qty }),
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          throw new Error(data.error);
        }
      } catch {
        hint.textContent = 'Der Kauf ist momentan nicht verfügbar. Bitte später erneut versuchen.';
        (btn as HTMLButtonElement).disabled = false;
      }
    });
  });
</script>

<style>
  .shop { background: var(--bg-night); padding-bottom: clamp(4rem, 8vw, 6rem); }

  .products { display: grid; gap: 2rem; }

  .product {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    background: rgba(20, 25, 27, 0.5);
    border: 1px solid rgba(238, 208, 152, 0.14);
    border-radius: 12px;
    overflow: hidden;
  }

  .product-img { position: relative; }

  .product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: rgba(20, 25, 27, 0.85);
    color: var(--gold-soft);
    padding: 0.5rem 0.9rem;
    border-radius: 4px;
    border: 1px solid rgba(238, 208, 152, 0.3);
  }

  .product-body {
    padding: clamp(1.5rem, 4vw, 3rem) clamp(1.5rem, 4vw, 3rem) clamp(1.5rem, 4vw, 3rem) 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .name { font-size: clamp(1.5rem, 3vw, 2.1rem); }

  .unit { color: var(--text-muted); }

  .text { max-width: 44ch; }

  .buy-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.4rem;
    margin-top: 1rem;
  }

  .price {
    font-size: 2rem;
    color: var(--gold-soft);
  }

  .qty {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .qty select {
    background: transparent;
    border: 1px solid rgba(238, 208, 152, 0.3);
    border-radius: 4px;
    color: var(--text-bright);
    font-family: var(--font-sans);
    font-size: 1rem;
    padding: 0.55rem 0.7rem;
  }

  .qty select option { background: var(--bg-night); }

  .hint { font-size: 0.85rem; color: var(--rose); min-height: 1.2em; }

  /* advert */
  .advert {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    margin-top: 4rem;
  }

  .advert-img {
    border: 1px solid rgba(238, 208, 152, 0.35);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
    max-width: 380px;
  }

  .advert-img img { width: 100%; height: auto; }

  .advert-copy h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--gold-soft);
    margin-bottom: 1.2rem;
  }

  .advert-copy a { color: var(--gold-soft); }

  .legal-note {
    margin-top: 3rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (max-width: 820px) {
    .product { grid-template-columns: 1fr; }
    .product-body { padding: 0 1.5rem 2rem; }
    .advert { grid-template-columns: 1fr; }
    .advert-img { margin-inline: auto; }
  }
</style>
