---
// Home-page teaser for the shop, using the advert image.
---
<section class="teaser">
  <div class="container grid">
    <figure class="photo reveal">
      <img
        src="/images/shop-advert.jpg"
        alt="Enilaangel in der Salzgrotte mit Himalaya Pink Salt"
        loading="lazy"
        width="1023"
        height="1537"
      />
    </figure>

    <div class="copy reveal">
      <p class="eyebrow eyebrow--gold tag">★ &nbsp;Neu im Shop</p>
      <h2 class="serif heading">Produkte,<br />die Gutes tun.</h2>
      <p class="lead">
        Vom Himalaya Pink Salt bis zu weiteren Charity-Produkten - jeder
        Kauf unterstützt das Projekt „Kleiner Stern ganz groß" und damit
        krebskranke Kinder.
      </p>
      <a class="btn-gold" href="/shop">Zum Shop</a>
    </div>
  </div>
</section>

<style>
  .teaser { background: var(--bg-night); }

  .grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  .photo {
    border: 1px solid rgba(238, 208, 152, 0.35);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
    max-width: 440px;
  }

  .photo img { width: 100%; height: auto; }

  .tag {
    border-bottom: 1px solid var(--gold-dim);
    display: inline-block;
    padding-bottom: 0.8rem;
    margin-bottom: 2rem;
  }

  .heading {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    color: var(--gold-soft);
    line-height: 1.15;
    margin-bottom: 1.6rem;
  }

  .lead {
    font-size: 1.1rem;
    margin-bottom: 2.2rem;
    max-width: 34em;
  }

  @media (max-width: 820px) {
    .grid { grid-template-columns: 1fr; }
    .photo { margin-inline: auto; }
    .copy { text-align: center; }
    .tag { margin-inline: auto; }
    .lead { margin-inline: auto; }
  }
</style>
