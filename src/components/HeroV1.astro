---
---
<header class="hero">
  <!-- Twinkling starfield -->
  <div class="stars stars-a" aria-hidden="true"></div>
  <div class="stars stars-b" aria-hidden="true"></div>

  <div class="container hero-grid">
    <!-- ============ Text ============ -->
    <div class="hero-copy">
      <p class="eyebrow tagline">
        Ein Song &nbsp;·&nbsp; Eine Mission &nbsp;·&nbsp; Ein Herz für Kinder
      </p>

      <h1>
        <span class="script hero-script">Kleiner Stern</span>
        <span class="serif hero-serif">Ganz Gross</span>
      </h1>

      <p class="eyebrow hero-by">Von Enilaangel</p>

      <div class="hero-actions">
        <button class="btn-gold js-buy-song">♫ &nbsp;Jetzt anhören · 0,99 €</button>
      </div>

      <p class="hero-note">
        <svg class="mini-ribbon" viewBox="0 0 120 160" width="15" height="20" aria-hidden="true">
          <g fill="var(--gold)">
            <path d="M45 60 L88 146 L106 136 L64 56 Z" opacity="0.8" />
            <path d="M75 60 L32 146 L14 136 L56 56 Z" />
          </g>
          <ellipse cx="60" cy="42" rx="24" ry="33" fill="none" stroke="var(--gold)" stroke-width="15" />
        </svg>
        100 % digital &nbsp;·&nbsp; <strong>50 %</strong> direkt an krebskranke Kinder
      </p>
    </div>

    <!-- ============ Emblem: child in golden circle ============ -->
    <div class="hero-emblem" aria-hidden="true">
      <div class="halo"></div>

      <svg class="emblem" viewBox="0 0 220 220" width="420" height="420">
        <defs>
          <radialGradient id="circleGold" cx="42%" cy="34%" r="75%">
            <stop offset="0%" stop-color="#f8e6c0" />
            <stop offset="58%" stop-color="#eed098" />
            <stop offset="100%" stop-color="#c9a876" />
          </radialGradient>
          <clipPath id="circleClip">
            <circle cx="110" cy="110" r="100" />
          </clipPath>
        </defs>

        <!-- golden circle -->
        <circle cx="110" cy="110" r="100" fill="url(#circleGold)" />

        <!-- child reaching for a little star (negative space) -->
        <g clip-path="url(#circleClip)" fill="var(--bg-deep)">
          <circle cx="98" cy="121" r="19" />
          <path d="M86 138
            C77 153 74 175 74 210
            L130 210
            C130 185 129 165 125 152
            C136 138 143 120 148 103
            C150 98 152 94 153 91
            C155 88 152 84 148 86
            C144 92 140 98 136 105
            C131 118 124 132 110 138 Z" />
          <circle cx="150" cy="89" r="4.5" />
        </g>

        <!-- the little star, glowing -->
        <path class="little-star"
          fill="#fffdf7"
          d="M158 53 L161.2 61.6 L170.4 62 L163.2 67.7 L165.6 76.5 L158 71.5 L150.4 76.5 L152.8 67.7 L145.6 62 L154.8 61.6 Z" />

        <!-- sparkles -->
        <g class="sparkle s1" fill="var(--text-bright)">
          <path d="M0 -6 L1.5 -1.5 L6 0 L1.5 1.5 L0 6 L-1.5 1.5 L-6 0 L-1.5 -1.5 Z" />
        </g>
        <g class="sparkle s2" fill="var(--text-bright)" opacity="0.8">
          <path d="M0 -4.5 L1.2 -1.2 L4.5 0 L1.2 1.2 L0 4.5 L-1.2 1.2 L-4.5 0 L-1.2 -1.2 Z" />
        </g>
        <g class="sparkle s3" fill="#fffdf7" opacity="0.9">
          <path d="M0 -3.5 L1 -1 L3.5 0 L1 1 L0 3.5 L-1 1 L-3.5 0 L-1 -1 Z" />
        </g>
      </svg>

      <!-- gold awareness ribbon, overlapping the circle -->
      <svg class="ribbon" viewBox="0 0 120 160" width="110" height="147">
        <defs>
          <linearGradient id="ribbonGold" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#f8e6c0" />
            <stop offset="55%" stop-color="#eed098" />
            <stop offset="100%" stop-color="#c9a876" />
          </linearGradient>
          <linearGradient id="ribbonGoldDark" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#e3c391" />
            <stop offset="100%" stop-color="#b3905e" />
          </linearGradient>
          <g id="ribbon-shape">
            <path d="M45 60 L88 146 L106 136 L64 56 Z" fill="url(#ribbonGoldDark)" />
            <path d="M75 60 L32 146 L14 136 L56 56 Z" fill="url(#ribbonGold)" />
            <ellipse cx="60" cy="42" rx="24" ry="33" fill="none"
                     stroke="url(#ribbonGold)" stroke-width="15" />
          </g>
        </defs>
        <use href="#ribbon-shape" />
      </svg>
    </div>
  </div>

  <a href="#quote" class="hero-scroll" aria-label="Weiter scrollen">
    <span>Weiter</span>
    <svg width="16" height="28" viewBox="0 0 16 28" fill="none">
      <path d="M8 2 V24 M2 18 L8 25 L14 18" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>
  </a>
</header>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background:
      radial-gradient(ellipse 70% 55% at 72% 40%, rgba(201, 168, 118, 0.14), transparent 68%),
      radial-gradient(ellipse 90% 70% at 20% 90%, rgba(43, 53, 56, 0.9), transparent),
      var(--bg-deep);
    padding: 4rem 0 5.5rem;
  }

  /* ---------- starfield ---------- */
  .stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1.4px 1.4px at 8% 22%, rgba(245,242,236,0.9), transparent 60%),
      radial-gradient(1px 1px at 21% 68%, rgba(245,242,236,0.7), transparent 60%),
      radial-gradient(1.8px 1.8px at 33% 15%, rgba(238,208,152,0.9), transparent 60%),
      radial-gradient(1px 1px at 46% 84%, rgba(245,242,236,0.6), transparent 60%),
      radial-gradient(1.3px 1.3px at 58% 30%, rgba(245,242,236,0.85), transparent 60%),
      radial-gradient(1px 1px at 67% 74%, rgba(238,208,152,0.7), transparent 60%),
      radial-gradient(1.6px 1.6px at 79% 12%, rgba(245,242,236,0.9), transparent 60%),
      radial-gradient(1px 1px at 88% 55%, rgba(245,242,236,0.65), transparent 60%),
      radial-gradient(1.2px 1.2px at 94% 82%, rgba(238,208,152,0.8), transparent 60%),
      radial-gradient(1px 1px at 14% 45%, rgba(245,242,236,0.55), transparent 60%),
      radial-gradient(1.5px 1.5px at 72% 92%, rgba(245,242,236,0.75), transparent 60%),
      radial-gradient(1px 1px at 40% 52%, rgba(238,208,152,0.6), transparent 60%);
    animation: twinkle-a 4.5s ease-in-out infinite;
    pointer-events: none;
  }

  .stars-b {
    background-image:
      radial-gradient(1px 1px at 12% 80%, rgba(245,242,236,0.8), transparent 60%),
      radial-gradient(1.5px 1.5px at 27% 35%, rgba(238,208,152,0.85), transparent 60%),
      radial-gradient(1px 1px at 51% 10%, rgba(245,242,236,0.7), transparent 60%),
      radial-gradient(1.3px 1.3px at 63% 60%, rgba(245,242,236,0.8), transparent 60%),
      radial-gradient(1px 1px at 83% 28%, rgba(238,208,152,0.75), transparent 60%),
      radial-gradient(1.6px 1.6px at 96% 40%, rgba(245,242,236,0.85), transparent 60%),
      radial-gradient(1px 1px at 5% 60%, rgba(245,242,236,0.6), transparent 60%),
      radial-gradient(1.2px 1.2px at 37% 93%, rgba(238,208,152,0.7), transparent 60%);
    animation: twinkle-b 6s ease-in-out infinite;
  }

  @keyframes twinkle-a { 0%,100% { opacity: 1; } 50% { opacity: 0.35; } }
  @keyframes twinkle-b { 0%,100% { opacity: 0.4; } 50% { opacity: 1; } }

  /* ---------- layout ---------- */
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    text-align: left;
  }

  .hero-script {
    display: block;
    font-size: clamp(3.4rem, 8vw, 6rem);
    text-shadow: 0 0 60px rgba(232, 201, 160, 0.35);
  }

  .hero-serif {
    display: block;
    font-size: clamp(1.8rem, 4.5vw, 3.2rem);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-top: 0.8rem;
  }

  .hero-by { color: var(--text-muted); }

  .hero-actions { margin-top: 0.5rem; }

  .hero-note {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .hero-note strong { color: var(--text-bright); font-weight: 500; }

  .mini-ribbon { flex: none; filter: drop-shadow(0 0 6px rgba(238,208,152,0.5)); }

  /* ---------- emblem ---------- */
  .hero-emblem {
    position: relative;
    display: grid;
    place-items: center;
    justify-self: center;
  }

  .halo {
    position: absolute;
    width: 118%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(238, 208, 152, 0.28), transparent 65%);
    animation: halo-pulse 5s ease-in-out infinite;
  }

  @keyframes halo-pulse {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.07); opacity: 1; }
  }

  .emblem {
    position: relative;
    width: clamp(260px, 32vw, 420px);
    height: auto;
    filter: drop-shadow(0 18px 60px rgba(0, 0, 0, 0.55));
  }

  .little-star {
    filter: drop-shadow(0 0 8px rgba(255, 253, 247, 0.95));
    animation: star-pulse 3s ease-in-out infinite;
    transform-origin: 158px 65px;
  }

  @keyframes star-pulse {
    0%, 100% { transform: scale(1); filter: drop-shadow(0 0 6px rgba(255,253,247,0.8)); }
    50% { transform: scale(1.12); filter: drop-shadow(0 0 14px rgba(255,253,247,1)); }
  }

  .sparkle { transform-origin: center; }
  .s1 { transform: translate(52px, 58px); animation: sparkle-pulse 4s ease-in-out infinite; }
  .s2 { transform: translate(168px, 140px); animation: sparkle-pulse 5.2s ease-in-out infinite 1s; }
  .s3 { transform: translate(70px, 172px); animation: sparkle-pulse 4.4s ease-in-out infinite 2s; }

  @keyframes sparkle-pulse {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 1; }
  }

  .ribbon {
    position: absolute;
    bottom: -8%;
    left: -4%;
    filter: drop-shadow(0 0 24px rgba(238, 208, 152, 0.45));
    animation: ribbon-glow 4s ease-in-out infinite;
  }

  @keyframes ribbon-glow {
    0%, 100% { filter: drop-shadow(0 0 16px rgba(238, 208, 152, 0.35)); }
    50% { filter: drop-shadow(0 0 30px rgba(238, 208, 152, 0.65)); }
  }

  /* ---------- scroll hint ---------- */
  .hero-scroll {
    position: absolute;
    bottom: 1.6rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    animation: floaty 2.6s ease-in-out infinite;
  }

  @keyframes floaty {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ---------- responsive ---------- */
  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; text-align: center; }
    .hero-copy { align-items: center; text-align: center; order: 2; }
    .hero-emblem { order: 1; }
    .emblem { width: clamp(220px, 55vw, 300px); }
    .ribbon { width: 80px; height: auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    .stars, .halo, .sparkle, .little-star, .ribbon, .hero-scroll { animation: none; }
  }
</style>
