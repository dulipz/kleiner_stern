---
// Hörprobe: 30-second preview player + buy CTA.
// Replace public/audio/kleiner-stern-preview.mp3 with the real 30s clip.
---
<section id="hoerprobe" class="player-section">
  <div class="container reveal inner">
    <p class="eyebrow eyebrow--gold">Hörprobe</p>
    <h2 class="serif heading">Hör den kleinen Stern.</h2>
    <p class="serif sub">30 Sekunden, die alles sagen.</p>

    <div class="player">
      <img
        class="cover"
        src="/images/cover-kleiner-stern.jpg"
        alt="Cover: Kleiner Stern ganz groß"
        loading="lazy"
        width="88"
        height="113"
      />

      <button class="play js-play" aria-label="Hörprobe abspielen">
        <svg class="icon-play" viewBox="0 0 24 24" width="26" height="26" fill="currentColor">
          <path d="M8 5 L19 12 L8 19 Z" />
        </svg>
        <svg class="icon-pause" viewBox="0 0 24 24" width="26" height="26" fill="currentColor" hidden>
          <path d="M7 5 h3.5 v14 H7 Z M13.5 5 H17 v14 h-3.5 Z" />
        </svg>
      </button>

      <div class="track">
        <div class="meta">
          <span class="title">Kleiner Stern ganz groß</span>
          <span class="time"><span class="js-current">0:00</span> / <span class="js-total">0:30</span></span>
        </div>
        <div class="bar js-bar" role="slider" aria-label="Abspielposition" aria-valuemin="0" aria-valuemax="30" tabindex="0">
          <div class="bar-fill js-fill"></div>
        </div>
        <span class="note">Hörprobe · der ganze Song nach dem Kauf</span>
      </div>

      <audio class="js-audio" src="/audio/kleiner-stern-preview.mp3" preload="metadata"></audio>
    </div>

    <button class="btn-gold js-buy-song">♫ &nbsp;Ganzen Song kaufen · 0,99 €</button>
    <p class="hint">Sofort-Download als MP3 nach der Zahlung. 50 % gehen an die KKAD e.V.</p>
  </div>
</section>

<script>
  const section = document.getElementById('hoerprobe');
  if (section) {
    const audio = section.querySelector('.js-audio') as HTMLAudioElement;
    const playBtn = section.querySelector('.js-play') as HTMLButtonElement;
    const iconPlay = section.querySelector('.icon-play') as SVGElement;
    const iconPause = section.querySelector('.icon-pause') as SVGElement;
    const fill = section.querySelector('.js-fill') as HTMLElement;
    const bar = section.querySelector('.js-bar') as HTMLElement;
    const current = section.querySelector('.js-current') as HTMLElement;
    const total = section.querySelector('.js-total') as HTMLElement;

    const fmt = (s: number) =>
      `${Math.floor(s / 60)}:${String(Math.floor(s % 60)).padStart(2, '0')}`;

    audio.addEventListener('loadedmetadata', () => {
      if (Number.isFinite(audio.duration)) total.textContent = fmt(audio.duration);
    });

    playBtn.addEventListener('click', () => {
      if (audio.paused) audio.play();
      else audio.pause();
    });

    audio.addEventListener('play', () => {
      iconPlay.setAttribute('hidden', '');
      iconPause.removeAttribute('hidden');
    });

    const showPlay = () => {
      iconPause.setAttribute('hidden', '');
      iconPlay.removeAttribute('hidden');
    };
    audio.addEventListener('pause', showPlay);
    audio.addEventListener('ended', () => {
      showPlay();
      audio.currentTime = 0;
      fill.style.width = '0%';
    });

    audio.addEventListener('timeupdate', () => {
      if (audio.duration) {
        fill.style.width = `${(audio.currentTime / audio.duration) * 100}%`;
        current.textContent = fmt(audio.currentTime);
      }
    });

    bar.addEventListener('click', (e) => {
      const rect = bar.getBoundingClientRect();
      const pos = (e.clientX - rect.left) / rect.width;
      if (audio.duration) audio.currentTime = pos * audio.duration;
    });
  }
</script>

<style>
  .player-section {
    background:
      radial-gradient(ellipse 60% 55% at 50% 20%, rgba(238, 208, 152, 0.06), transparent),
      var(--bg-deep);
    text-align: center;
  }

  .inner { display: flex; flex-direction: column; align-items: center; gap: 1.4rem; }

  .heading { font-size: clamp(2rem, 5vw, 3.2rem); }

  .sub {
    font-style: italic;
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    color: var(--text-muted);
  }

  .player {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    width: min(620px, 100%);
    background: rgba(20, 25, 27, 0.6);
    border: 1px solid rgba(238, 208, 152, 0.18);
    border-radius: 12px;
    padding: 1.1rem 1.4rem;
    margin-top: 1.4rem;
    text-align: left;
  }

  .cover {
    border-radius: 6px;
    flex: none;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
  }

  .play {
    flex: none;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #f3dcae 0%, var(--gold) 55%, #ddb87e 100%);
    color: #1a1408;
    box-shadow: 0 4px 20px rgba(238, 208, 152, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .play:hover {
    transform: scale(1.06);
    box-shadow: 0 6px 28px rgba(238, 208, 152, 0.5);
  }

  .track { flex: 1; min-width: 0; }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.55rem;
  }

  .title {
    font-family: var(--font-serif);
    color: var(--text-bright);
    font-size: 1.05rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .time {
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    flex: none;
  }

  .bar {
    height: 6px;
    background: rgba(238, 208, 152, 0.15);
    border-radius: 3px;
    cursor: pointer;
  }

  .bar-fill {
    height: 100%;
    width: 0%;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--gold-dim), var(--gold));
    transition: width 0.15s linear;
  }

  .note {
    display: block;
    margin-top: 0.55rem;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .hint { font-size: 0.85rem; color: var(--text-muted); }

  @media (max-width: 560px) {
    .player { flex-wrap: wrap; justify-content: center; }
    .cover { display: none; }
  }
</style>
