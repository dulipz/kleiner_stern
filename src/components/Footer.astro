---
---
<footer class="footer">
  <div class="container grid">
    <div class="brand">
      <img class="logo-img" src="/images/enila-logo.png" alt="Enilaangel" width="1247" height="758" loading="lazy" />
    </div>

    <nav aria-label="Projekt">
      <p class="eyebrow eyebrow--gold col-title">Projekt</p>
      <ul>
        <li><a href="/ueber">Über das Projekt</a></li>
        <li><a href="/shop">Shop</a></li>
        <li><a href="/presse">Presse</a></li>
        <li><a href="/partner">Partner &amp; Unterstützer</a></li>
      </ul>
    </nav>

    <nav aria-label="Song kaufen">
      <p class="eyebrow eyebrow--gold col-title">Song kaufen</p>
      <ul>
        <li><a href="https://www.qobuz.com" target="_blank" rel="noopener">Qobuz</a></li>
        <li><a href="https://topgear-sport.de" target="_blank" rel="noopener">Topgear Ball · Projekt unterstützen</a></li>
        <li><a href="https://www.kinderkrebsaktion.de" target="_blank" rel="noopener">KKAD unterstützen</a></li>
      </ul>
    </nav>

    <nav aria-label="Information">
      <p class="eyebrow eyebrow--gold col-title">Information</p>
      <ul>
        <li><a href="https://www.kinderkrebsaktion.de" target="_blank" rel="noopener">Kinder Krebs Aktion e.V.</a></li>
        <li><a href="/impressum">Impressum</a></li>
        <li><a href="/datenschutz">Datenschutz</a></li>
        <li><a href="mailto:info@enilaangel.com">info@enilaangel.com</a></li>
      </ul>
    </nav>
  </div>

  <div class="container bottom">
    <p>© {new Date().getFullYear()} Enilaangel · Kleiner Stern ganz groß</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-footer);
    padding: 4.5rem 0 2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }

  .logo-img {
    height: 84px;
    width: auto;
    filter: drop-shadow(0 0 18px rgba(232, 201, 160, 0.3));
  }

  .col-title { margin-bottom: 1.4rem; }

  ul { list-style: none; }

  li { margin-bottom: 0.9rem; }

  a {
    color: var(--text-body);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover { color: var(--gold-soft); }

  .bottom {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(238, 208, 152, 0.08);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; gap: 2.2rem; }
  }
</style>
