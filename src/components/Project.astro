---
---
<section class="project">
  <div class="container grid">
    <div class="copy reveal">
      <p class="eyebrow eyebrow--gold section-tag">★ &nbsp;Charity-Sektion</p>
      <h2 class="serif heading">Projekt<br />unterstützen</h2>
      <p class="lead">
        Topgear Ball kaufen und das Charity-Projekt „Kleiner Stern ganz groß" unterstützen.
      </p>
      <div class="rule" aria-hidden="true"><span>✦</span></div>
      <p class="text">
        Pro verkauftem Ball geht ein Teil des Erlöses an krebskranke Kinder.
        Gemeinsam schenken wir Hoffnung, Mut und direkte Unterstützung.
      </p>
      <a class="btn-ghost" href="https://topgear-sport.de" target="_blank" rel="noopener">
        Zum Topgear Ball
      </a>
    </div>

    <figure class="photo reveal">
      <img src="/images/topgear-ball.jpg" alt="Topgear Fußbälle auf dem Rasen" loading="lazy" width="1111" height="595" />
    </figure>
  </div>
</section>

<style>
  .project { background: var(--bg-navy); }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  .section-tag {
    border-bottom: 1px solid var(--gold-dim);
    display: inline-block;
    padding-bottom: 0.8rem;
    margin-bottom: 2rem;
  }

  .heading {
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    color: var(--gold-soft);
    line-height: 1.15;
    margin-bottom: 1.6rem;
  }

  .lead {
    font-size: 1.15rem;
    color: var(--text-bright);
  }

  .rule {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--gold-dim);
    margin: 1.8rem 0;
  }

  .rule::before {
    content: '';
    height: 1px;
    width: 130px;
    background: linear-gradient(90deg, var(--gold-dim), transparent);
  }

  .text { margin-bottom: 2.2rem; }

  .photo {
    border: 1px solid rgba(238, 208, 152, 0.4);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
    position: relative;
  }

  .photo::after {
    content: '✦';
    position: absolute;
    top: -14px;
    right: -6px;
    color: var(--gold);
    text-shadow: 0 0 16px rgba(238, 208, 152, 0.9);
  }

  .photo img { width: 100%; height: 100%; object-fit: cover; }

  @media (max-width: 820px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
